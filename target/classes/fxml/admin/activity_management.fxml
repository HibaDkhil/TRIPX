<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.Tooltip?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx/8.0.171"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="tn.esprit.controllers.admin.ActivityManagementController"
            stylesheets="@../../css/destination.css">

    <top>
        <VBox spacing="15" styleClass="header-section">
            <padding>
                <Insets top="20" right="25" left="25" bottom="15"/>
            </padding>

            <HBox alignment="CENTER_LEFT" spacing="10">
                <Label text="🛶 Activity Management" styleClass="page-title"/>
                <Label fx:id="totalActivitiesLabel" text="Total: 0" styleClass="stat-badge"/>
                <Button fx:id="themeBtn" text="🌙" styleClass="theme-toggle-btn"/>
                <javafx.scene.layout.Region HBox.hgrow="ALWAYS" />
                <Button fx:id="backBtn" text="⬅ Back to Destinations" styleClass="action-button"/>
            </HBox>

            <Label text="Manage activities for your destinations" styleClass="page-subtitle"/>
            <Separator styleClass="section-separator"/>
        </VBox>
    </top>

    <center>
        <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
            <content>
                <VBox spacing="20" styleClass="content-section">
                    <padding>
                        <Insets top="5" right="25" left="25" bottom="25"/>
                    </padding>

                    <!-- Search and Filter Bar -->
                    <HBox spacing="15" alignment="CENTER_LEFT">
                        <TextField fx:id="searchField" promptText="Search activity..."
                                   HBox.hgrow="ALWAYS" styleClass="search-field"/>

                        <ComboBox fx:id="destFilterCombo" prefWidth="200" styleClass="filter-combo"
                                  promptText="Filter by Destination"/>

                        <Button fx:id="searchBtn" text="🔍 Search" styleClass="action-button"/>
                        <Button fx:id="refreshBtn" text="🔄 Refresh" styleClass="action-button"/>
                        <Button fx:id="addNewBtn" text="➕ Add New Activity" styleClass="action-button-primary"/>
                    </HBox>

                    <HBox spacing="10" styleClass="stats-bar">
                        <Label fx:id="statusLabel" text="Ready" styleClass="status-label"/>
                    </HBox>

                    <GridPane hgap="20" vgap="10">
                        <columnConstraints>
                            <ColumnConstraints percentWidth="65" />
                            <ColumnConstraints percentWidth="35" />
                        </columnConstraints>

                        <!-- Left: Activities Table -->
                        <VBox spacing="10" GridPane.columnIndex="0">
                            <Label text="Activities List" styleClass="section-label"/>
                            <TableView fx:id="activityTable" minHeight="450" VBox.vgrow="ALWAYS" styleClass="destination-table">
                                <columns>
                                    <TableColumn fx:id="colName" text="Activity Name" prefWidth="150"/>
                                    <TableColumn fx:id="colDest" text="Destination" prefWidth="120"/>
                                    <TableColumn fx:id="colCategory" text="Category" prefWidth="100"/>
                                    <TableColumn fx:id="colPrice" text="Price" prefWidth="80"/>
                                    <TableColumn fx:id="colCapacity" text="Capacity" prefWidth="80"/>
                                    <TableColumn fx:id="colActions" text="Actions" prefWidth="100"/>
                                </columns>
                            </TableView>
                        </VBox>

                        <!-- Right: Form -->
                        <VBox spacing="15" GridPane.columnIndex="1" styleClass="form-section">
                            <Label text="Activity Details" styleClass="section-label"/>

                            <GridPane hgap="10" vgap="12">
                                <columnConstraints>
                                    <ColumnConstraints percentWidth="35" />
                                    <ColumnConstraints percentWidth="65" />
                                </columnConstraints>

                                <!-- Destination Selection -->
                                <Label text="Destination *" GridPane.rowIndex="0" GridPane.columnIndex="0" styleClass="form-label"/>
                                <ComboBox fx:id="destCombo" prefWidth="250"
                                          GridPane.rowIndex="0" GridPane.columnIndex="1" styleClass="form-combo"/>

                                <!-- Name -->
                                <Label text="Name *" GridPane.rowIndex="1" GridPane.columnIndex="0" styleClass="form-label"/>
                                <TextField fx:id="nameField" promptText="Activity Name"
                                           GridPane.rowIndex="1" GridPane.columnIndex="1" styleClass="form-field"/>

                                <!-- Category -->
                                <Label text="Category *" GridPane.rowIndex="2" GridPane.columnIndex="0" styleClass="form-label"/>
                                <ComboBox fx:id="categoryCombo" prefWidth="250"
                                          GridPane.rowIndex="2" GridPane.columnIndex="1" styleClass="form-combo"/>

                                <!-- Price -->
                                <Label text="Price ($) *" GridPane.rowIndex="3" GridPane.columnIndex="0" styleClass="form-label"/>
                                <TextField fx:id="priceField" promptText="0.0"
                                           GridPane.rowIndex="3" GridPane.columnIndex="1" styleClass="form-field"/>

                                <!-- Capacity -->
                                <Label text="Capacity *" GridPane.rowIndex="4" GridPane.columnIndex="0" styleClass="form-label"/>
                                <TextField fx:id="capacityField" promptText="Max people"
                                           GridPane.rowIndex="4" GridPane.columnIndex="1" styleClass="form-field"/>

                                <!-- Description -->
                                <Label text="Description" GridPane.rowIndex="5" GridPane.columnIndex="0" styleClass="form-label"/>
                                <TextArea fx:id="descArea" promptText="Details..."
                                          prefRowCount="4" wrapText="true"
                                          GridPane.rowIndex="5" GridPane.columnIndex="1" styleClass="form-textarea"/>
                            </GridPane>

                            <Separator/>

                            <HBox spacing="10" alignment="CENTER">
                                <Button fx:id="saveBtn" text="Save" styleClass="form-button-save" prefWidth="100"/>
                                <Button fx:id="clearBtn" text="Clear" styleClass="form-button-clear" prefWidth="100"/>
                            </HBox>
                        </VBox>
                    </GridPane>
                </VBox>
            </content>
        </ScrollPane>
    </center>
</BorderPane>
