<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.CheckBox?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.web.WebView?>

<StackPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.controllers.user.AccommodationsController"
           style="-fx-background-color: linear-gradient(to bottom right, #F8FAFC, #E0F2FE); -fx-font-family: 'Poppins', 'Inter', 'Segoe UI', 'Arial';">

    <BorderPane prefWidth="1600.0" prefHeight="950.0" style="-fx-background-color: #F8FAFC;">

        <top>
            <HBox alignment="CENTER_LEFT" spacing="22"
                  style="-fx-background-color: linear-gradient(to right, #FFFFFF, #ECFEFF); -fx-padding: 14 26; -fx-background-radius: 0 0 18 18; -fx-border-color: rgba(14,165,164,0.18); -fx-border-width: 0 0 1 0; -fx-effect: dropshadow(gaussian, rgba(31,41,55,0.10), 18, 0, 0, 4);">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <ImageView fitWidth="64" fitHeight="64" preserveRatio="true">
                        <image>
                            <Image url="@/images/tripx-logo.png"/>
                        </image>
                    </ImageView>
                    <Label text="TripX" style="-fx-font-size: 30; -fx-font-weight: 900; -fx-text-fill: #1E3A8A; -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.18), 8, 0, 0, 2);"/>
                </HBox>
                <Region HBox.hgrow="ALWAYS"/>

                <Button text="Destinations" styleClass="nav-tab"
                        style="-fx-background-color: rgba(37,99,235,0.06); -fx-text-fill: #1E3A8A; -fx-font-size: 14; -fx-font-weight: 700; -fx-background-radius: 999; -fx-padding: 8 14; -fx-cursor: hand;"/>
                <Button text="Accommodations"
                        style="-fx-background-color: linear-gradient(to right, #1E3A8A, #2563EB); -fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: 800; -fx-background-radius: 999; -fx-padding: 8 16; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.30), 10, 0, 0, 3);"/>
                <Button text="Transport"
                        style="-fx-background-color: rgba(20,184,166,0.08); -fx-text-fill: #0F766E; -fx-font-size: 14; -fx-font-weight: 700; -fx-background-radius: 999; -fx-padding: 8 14; -fx-cursor: hand;"/>
                <Button text="Offers"
                        style="-fx-background-color: rgba(37,99,235,0.06); -fx-text-fill: #1E3A8A; -fx-font-size: 14; -fx-font-weight: 700; -fx-background-radius: 999; -fx-padding: 8 14; -fx-cursor: hand;"/>
                <Button text="Blog"
                        style="-fx-background-color: rgba(20,184,166,0.08); -fx-text-fill: #0F766E; -fx-font-size: 14; -fx-font-weight: 700; -fx-background-radius: 999; -fx-padding: 8 14; -fx-cursor: hand;"/>
            </HBox>
        </top>

        <left>
            <VBox prefWidth="290" spacing="14"
                  style="-fx-background-color: linear-gradient(to bottom, #FFFFFF, #ECFEFF); -fx-padding: 18; -fx-border-color: #DBEAFE; -fx-border-width: 0 1 0 0; -fx-effect: dropshadow(gaussian, rgba(14,165,164,0.16), 14, 0, 2, 0);">
                <Label text="Filters" style="-fx-font-size: 19; -fx-font-weight: 900; -fx-text-fill: #1F2937;"/>
                <TextField fx:id="searchField" promptText="Search by name/city..."
                           style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #BAE6FD; -fx-border-radius: 12; -fx-padding: 10 12; -fx-font-size: 13; -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.09), 8, 0, 0, 2);"/>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <content>
                        <VBox spacing="14" style="-fx-background-color: transparent; -fx-padding: 0 2 8 0;">
                            <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #FFFFFF, #F0FDFA); -fx-background-radius: 14; -fx-padding: 12; -fx-border-color: rgba(20,184,166,0.2); -fx-border-width: 1; -fx-border-radius: 14; -fx-effect: dropshadow(gaussian, rgba(14,165,164,0.12), 10, 0, 0, 2);">
                                <Label text="Price Range" style="-fx-font-size: 13; -fx-font-weight: 700; -fx-text-fill: #1F2937;"/>
                                <Label fx:id="priceRangeLabel" text="Up to $1000/night" style="-fx-text-fill: #0EA5A4; -fx-font-weight: 700;"/>
                                <Slider fx:id="priceSlider" min="50" max="1000" value="1000" blockIncrement="50"/>
                            </VBox>

                            <Separator visible="false" managed="false"/>

                            <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #FFFFFF, #EFF6FF); -fx-background-radius: 14; -fx-padding: 12; -fx-border-color: rgba(37,99,235,0.18); -fx-border-width: 1; -fx-border-radius: 14; -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.10), 10, 0, 0, 2);">
                                <Label text="Minimum Rating" style="-fx-font-size: 13; -fx-font-weight: 700; -fx-text-fill: #1F2937;"/>
                                <ComboBox fx:id="minRatingCombo" prefWidth="220"/>
                            </VBox>

                            <Separator visible="false" managed="false"/>

                            <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #FFFFFF, #EFF6FF); -fx-background-radius: 14; -fx-padding: 12; -fx-border-color: rgba(37,99,235,0.18); -fx-border-width: 1; -fx-border-radius: 14; -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.10), 10, 0, 0, 2);">
                                <Label text="Accommodation Type" style="-fx-font-size: 13; -fx-font-weight: 700; -fx-text-fill: #1F2937;"/>
                                <CheckBox fx:id="typeHotelCheck" text="Hotel"/>
                                <CheckBox fx:id="typeApartmentCheck" text="Apartment"/>
                                <CheckBox fx:id="typeVillaCheck" text="Villa"/>
                                <CheckBox fx:id="typeResortCheck" text="Resort"/>
                                <CheckBox fx:id="typeHostelCheck" text="Hostel"/>
                            </VBox>

                            <Separator visible="false" managed="false"/>

                            <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #FFFFFF, #F0FDFA); -fx-background-radius: 14; -fx-padding: 12; -fx-border-color: rgba(20,184,166,0.2); -fx-border-width: 1; -fx-border-radius: 14; -fx-effect: dropshadow(gaussian, rgba(14,165,164,0.12), 10, 0, 0, 2);">
                                <Label text="Amenities" style="-fx-font-size: 13; -fx-font-weight: 700; -fx-text-fill: #1F2937;"/>
                                <CheckBox fx:id="amenityWifiCheck" text="WiFi"/>
                                <CheckBox fx:id="amenityPoolCheck" text="Pool"/>
                                <CheckBox fx:id="amenityParkingCheck" text="Parking"/>
                                <CheckBox fx:id="amenitySpaCheck" text="Spa"/>
                            </VBox>

                            <Separator visible="false" managed="false"/>

                            <VBox spacing="8" style="-fx-background-color: linear-gradient(to bottom right, #FFFFFF, #F0FDFA); -fx-background-radius: 14; -fx-padding: 12; -fx-border-color: rgba(20,184,166,0.2); -fx-border-width: 1; -fx-border-radius: 14; -fx-effect: dropshadow(gaussian, rgba(14,165,164,0.12), 10, 0, 0, 2);">
                                <Label text="Dates" style="-fx-font-size: 13; -fx-font-weight: 700; -fx-text-fill: #1F2937;"/>
                                <DatePicker fx:id="checkInDatePicker" promptText="Check-in"/>
                                <DatePicker fx:id="checkOutDatePicker" promptText="Check-out"/>
                            </VBox>
                        </VBox>
                    </content>
                </ScrollPane>
            </VBox>
        </left>

        <center>
            <VBox spacing="10" style="-fx-padding: 20;">
                <Label fx:id="resultsCountLabel" text="0 accommodations found"
                       style="-fx-text-fill: #1F2937; -fx-font-size: 15; -fx-font-weight: 800;"/>

                <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS"
                            style="-fx-background-color: transparent; -fx-border-color: transparent;">
                    <content>
                        <GridPane fx:id="accommodationsGrid" hgap="16" vgap="16"
                                  style="-fx-padding: 6; -fx-background-color: rgba(255,255,255,0.45); -fx-background-radius: 16;">
                            <columnConstraints>
                                <ColumnConstraints hgrow="ALWAYS"/>
                                <ColumnConstraints hgrow="ALWAYS"/>
                            </columnConstraints>
                        </GridPane>
                    </content>
                </ScrollPane>
            </VBox>
        </center>

        <right>
            <VBox fx:id="mapPanel" prefWidth="380" spacing="8"
                  style="-fx-background-color: linear-gradient(to bottom, #FFFFFF, #ECFEFF); -fx-padding: 12; -fx-border-color: #DBEAFE; -fx-border-width: 0 0 0 1; -fx-effect: dropshadow(gaussian, rgba(14,165,164,0.14), 12, 0, -2, 0);">
                <HBox alignment="CENTER_LEFT" spacing="8">
                    <Label text="Map" style="-fx-font-size: 15; -fx-font-weight: 800; -fx-text-fill: #1F2937;"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="mapToggleButton" text="⟨"
                            onAction="#toggleMapPanel"
                            style="-fx-background-color: linear-gradient(to right, #0EA5A4, #14B8A6); -fx-text-fill: white; -fx-background-radius: 8; -fx-cursor: hand; -fx-font-weight: 700;"/>
                </HBox>
                <WebView fx:id="mapWebView" VBox.vgrow="ALWAYS" style="-fx-background-radius: 12;"/>
            </VBox>
        </right>
    </BorderPane>

    <HBox fx:id="compareBar" visible="false" managed="false" alignment="CENTER_LEFT" spacing="12"
          maxWidth="900" prefHeight="62" maxHeight="62" StackPane.alignment="BOTTOM_CENTER"
          style="-fx-background-color: linear-gradient(to right, #1E3A8A, #2563EB); -fx-background-radius: 16; -fx-padding: 12 18; -fx-border-color: rgba(255,255,255,0.2); -fx-border-width: 1; -fx-border-radius: 16; -fx-effect: dropshadow(gaussian, rgba(30,58,138,0.35), 18, 0, 0, 6);">
        <StackPane.margin>
            <Insets top="0" right="0" bottom="18" left="0"/>
        </StackPane.margin>
        <Label text="AI Compare" style="-fx-text-fill: white; -fx-font-size: 14; -fx-font-weight: 800;"/>
        <Label fx:id="compareCountLabel" text="0 / 3 selected" style="-fx-text-fill: #DBEAFE; -fx-font-weight: 700;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="compareNowButton" text="Compare Selected"
                style="-fx-background-color: linear-gradient(to right, #0EA5A4, #14B8A6); -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 12; -fx-cursor: hand;"/>
    </HBox>
</StackPane>
