    <!-- FLOATING AI ASSISTANT COMPONENTS -->
    <AnchorPane pickOnBounds="false">

        <!-- Chat Panel (Initially Hidden) -->
        <VBox fx:id="chatPanel" layoutX="780.0" layoutY="250.0" prefHeight="500.0" prefWidth="380.0"
              styleClass="ai-chat-panel" visible="false" AnchorPane.bottomAnchor="100.0" AnchorPane.rightAnchor="30.0">

            <HBox alignment="CENTER_LEFT" spacing="10.0" styleClass="ai-chat-header">
                <ImageView fitHeight="32.0" fitWidth="32.0" preserveRatio="true">
                    <image>
                        <Image url="@../../images/robot.png" />
                    </image>
                </ImageView>
                <Label styleClass="ai-header-title" text="TripX AI Assistant" />
                <Region HBox.hgrow="ALWAYS" />
                <Button onAction="#toggleChat" styleClass="ai-close-button" text="×" />
            </HBox>

            <ScrollPane fx:id="chatScrollPane" fitToWidth="true" VBox.vgrow="ALWAYS" styleClass="ai-chat-body">
                <VBox fx:id="chatMessageContainer" spacing="15.0" style="-fx-padding: 15;" />
            </ScrollPane>

            <HBox spacing="10.0" styleClass="ai-chat-footer">
                <TextField fx:id="chatInputField" onAction="#handleSendMessage" HBox.hgrow="ALWAYS"
                           promptText="Ask me anything about your trip..." styleClass="ai-input-field" />
                <Button onAction="#handleSendMessage" styleClass="ai-send-button" text="➤" />
            </HBox>
        </VBox>

        <!-- Floating Robot Button -->
        <Button fx:id="aiAssistantBtn" onAction="#toggleChat" styleClass="ai-floating-button"
                AnchorPane.bottomAnchor="30.0" AnchorPane.rightAnchor="30.0">
            <graphic>
                <ImageView fitHeight="48.0" fitWidth="48.0" preserveRatio="true">
                    <image>
                        <Image url="@../../images/robot.png" />
                    </image>
                </ImageView>
            </graphic>
        </Button>

    </AnchorPane>

</StackPane>
