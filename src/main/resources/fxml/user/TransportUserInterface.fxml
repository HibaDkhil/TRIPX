<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="1280" prefHeight="760"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.user.TransportUserInterfaceController"
            style="-fx-background-color: #F1EAE7;">

    <!-- ══════════════════════════════════════════════════════
         TOP SECTION  ─  kept exactly as before, plus tab bar
         ══════════════════════════════════════════════════════ -->
    <top>
        <VBox>

            <!-- ── Main nav row (unchanged) ── -->
            <HBox alignment="CENTER_LEFT" spacing="0"
                  style="-fx-background-color: #F5F0EB;
                         -fx-padding: 10 30 10 20;
                         -fx-border-color: transparent transparent #E0D8D3 transparent;
                         -fx-border-width: 0 0 1 0;">

                <!-- Logo -->
                <VBox alignment="CENTER_LEFT" spacing="-4" style="-fx-padding: 0 30 0 0;">
                    <Label text="TripX"
                           style="-fx-text-fill: #1F294C;
                                  -fx-font-size: 24px;
                                  -fx-font-weight: bold;" />
                </VBox>

                <!-- Nav links -->
                <HBox spacing="6" alignment="CENTER">
                    <Button text="Home"
                            style="-fx-background-color: transparent; -fx-text-fill: #1F294C;
                                   -fx-font-size: 13px; -fx-cursor: hand;
                                   -fx-border-color: transparent; -fx-padding: 8 12 8 12;" />
                    <Button text="Destinations"
                            style="-fx-background-color: transparent; -fx-text-fill: #1F294C;
                                   -fx-font-size: 13px; -fx-cursor: hand;
                                   -fx-border-color: transparent; -fx-padding: 8 12 8 12;" />
                    <Button text="Accommodations"
                            style="-fx-background-color: transparent; -fx-text-fill: #1F294C;
                                   -fx-font-size: 13px; -fx-cursor: hand;
                                   -fx-border-color: transparent; -fx-padding: 8 12 8 12;" />
                    <Button text="Activities"
                            style="-fx-background-color: transparent; -fx-text-fill: #1F294C;
                                   -fx-font-size: 13px; -fx-cursor: hand;
                                   -fx-border-color: transparent; -fx-padding: 8 12 8 12;" />
                    <!-- Transport = ACTIVE (teal underline) -->
                    <Button text="Transport"
                            style="-fx-background-color: transparent; -fx-text-fill: #4FB3B5;
                                   -fx-font-size: 13px; -fx-font-weight: bold; -fx-cursor: hand;
                                   -fx-border-color: transparent transparent #4FB3B5 transparent;
                                   -fx-border-width: 0 0 2 0; -fx-padding: 8 12 6 12;" />
                    <Button text="Blog"
                            style="-fx-background-color: transparent; -fx-text-fill: #1F294C;
                                   -fx-font-size: 13px; -fx-cursor: hand;
                                   -fx-border-color: transparent; -fx-padding: 8 12 8 12;" />
                </HBox>

                <Region HBox.hgrow="ALWAYS" />

                <!-- Welcome label -->
                <Label fx:id="welcomeLabel"
                       text="Welcome, Traveller"
                       style="-fx-text-fill: #4FB3B5; -fx-font-size: 12px;
                              -fx-padding: 0 16 0 0;" />

                <!-- Right buttons -->
                <HBox spacing="10" alignment="CENTER">
                    <Button text="My Profile"
                            style="-fx-background-color: transparent; -fx-text-fill: #1F294C;
                                   -fx-border-color: #1F294C; -fx-border-radius: 20;
                                   -fx-background-radius: 20; -fx-padding: 7 20 7 20;
                                   -fx-cursor: hand; -fx-font-size: 12px;" />
                    <Button text="Logout"
                            onAction="#handleLogout"
                            style="-fx-background-color: #F06E32; -fx-text-fill: white;
                                   -fx-border-color: transparent; -fx-border-radius: 20;
                                   -fx-background-radius: 20; -fx-padding: 7 20 7 20;
                                   -fx-cursor: hand; -fx-font-size: 12px;
                                   -fx-font-weight: bold;" />
                </HBox>
            </HBox>

            <!-- ── Transport module tab bar ── -->
            <HBox alignment="CENTER_LEFT" spacing="0"
                  style="-fx-background-color: white;
                         -fx-border-color: transparent transparent #D0C8C3 transparent;
                         -fx-border-width: 0 0 1 0;
                         -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.06), 4, 0, 0, 2);">

                <!-- ACTIVE by default = Schedules (controller sets active style in initialize) -->
                <Button fx:id="btnSchedules"
                        text="🗓   Schedules"
                        onAction="#showSchedulesTab"
                        style="-fx-background-color: #1F294C; -fx-text-fill: white;
                               -fx-font-weight: bold; -fx-font-size: 13px;
                               -fx-padding: 12 32 12 32; -fx-cursor: hand;
                               -fx-background-radius: 0; -fx-border-color: transparent;" />

                <Button fx:id="btnTransport"
                        text="✈   Transport"
                        onAction="#showTransportTab"
                        style="-fx-background-color: white; -fx-text-fill: #1F294C;
                               -fx-font-size: 13px; -fx-padding: 12 32 12 32;
                               -fx-cursor: hand; -fx-background-radius: 0;
                               -fx-border-color: transparent;" />

                <Button fx:id="btnMyBookings"
                        text="📋   My Bookings"
                        onAction="#showMyBookingsTab"
                        style="-fx-background-color: white; -fx-text-fill: #1F294C;
                               -fx-font-size: 13px; -fx-padding: 12 32 12 32;
                               -fx-cursor: hand; -fx-background-radius: 0;
                               -fx-border-color: transparent;" />

                <Region HBox.hgrow="ALWAYS" />
            </HBox>

        </VBox>
    </top>

    <!-- ══════════════════════════════════════════════════════
         CENTER CONTENT AREA  ─  no left sidebar
         ══════════════════════════════════════════════════════ -->
    <center>
        <StackPane fx:id="contentArea">
            <padding>
                <Insets top="22" right="26" bottom="22" left="26" />
            </padding>
        </StackPane>
    </center>

</BorderPane>
