<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.user.AccommodationCardController"
      prefWidth="340" spacing="10"
      style="-fx-background-color: linear-gradient(to bottom, #FFFFFF, #F8FAFC); -fx-background-radius: 18; -fx-padding: 12; -fx-border-color: #DBEAFE; -fx-border-width: 1; -fx-border-radius: 18; -fx-effect: dropshadow(gaussian, rgba(37,99,235,0.10), 16, 0, 0, 4);">

    <StackPane prefHeight="170" style="-fx-background-color: linear-gradient(to bottom right, #E2E8F0, #DBEAFE); -fx-background-radius: 12;">
        <ImageView fx:id="accommodationImageView" fitWidth="320" fitHeight="170" preserveRatio="false" smooth="true"/>
        <Label fx:id="imageFallbackLabel" text="No Image"
               style="-fx-text-fill: #64748B; -fx-font-size: 13; -fx-font-weight: 700;"/>
    </StackPane>

    <HBox alignment="CENTER_LEFT">
        <Label fx:id="nameLabel" text="Accommodation Name"
               style="-fx-font-size: 17; -fx-font-weight: 900; -fx-text-fill: #1F2937;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="starsLabel" text="★★★★★" style="-fx-text-fill: #F59E0B; -fx-font-size: 13; -fx-font-weight: 700;"/>
    </HBox>

    <Label fx:id="typeCityLabel" text="Type • City, Country"
           style="-fx-text-fill: #1E3A8A; -fx-font-size: 13; -fx-font-weight: 700;"/>

    <Label fx:id="addressLabel" text="Address"
           maxWidth="320" wrapText="true"
           style="-fx-text-fill: #64748B; -fx-font-size: 12;"/>

    <Label fx:id="amenitiesLabel" text="Amenities"
           maxWidth="320" wrapText="true"
           style="-fx-text-fill: #0EA5A4; -fx-font-size: 12; -fx-font-weight: 800;"/>

    <HBox alignment="CENTER_LEFT" spacing="8">
        <ToggleButton fx:id="compareToggleButton" text="Compare"
                      onAction="#onCompareToggle"
                      style="-fx-background-color: linear-gradient(to right, #EEF2FF, #DBEAFE); -fx-text-fill: #1E3A8A; -fx-font-weight: 800; -fx-background-radius: 10; -fx-cursor: hand;"/>
        <Button text="Details" onAction="#onDetails"
                style="-fx-background-color: #F1F5F9; -fx-text-fill: #64748B; -fx-font-weight: 700; -fx-background-radius: 10;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label fx:id="statusLabel" text="Active"
               style="-fx-background-color: #DCFCE7; -fx-text-fill: #166534; -fx-background-radius: 999; -fx-padding: 4 10; -fx-font-size: 11; -fx-font-weight: 700;"/>
    </HBox>

    <padding>
        <Insets top="12" right="12" bottom="12" left="12"/>
    </padding>
</VBox>
