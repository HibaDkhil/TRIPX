<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.admin.RoomDetailsController"
      spacing="0"
      prefWidth="980"
      maxWidth="980"
      style="-fx-background-color: #FFFFFF; -fx-background-radius: 16;">

    <HBox alignment="CENTER_LEFT" spacing="14"
          style="-fx-background-color: linear-gradient(to right, #0A4174, #4E8EA2); -fx-background-radius: 16 16 0 0; -fx-padding: 18 22;">
        <VBox spacing="5">
            <Label fx:id="pageTitleLabel" text="Room Details"
                   style="-fx-text-fill: white; -fx-font-size: 21; -fx-font-weight: 800;"/>
            <Label fx:id="breadcrumbsLabel" text="Dashboard > Accommodations > Room"
                   style="-fx-text-fill: rgba(255,255,255,0.9); -fx-font-size: 12;"/>
        </VBox>
        <Region HBox.hgrow="ALWAYS"/>
        <Button text="← Back to Accommodation" onAction="#handleBackToAccommodation"
                style="-fx-background-color: rgba(255,255,255,0.18); -fx-text-fill: white; -fx-font-weight: 700; -fx-background-radius: 10; -fx-padding: 8 14; -fx-cursor: hand;"/>
        <Button text="✕" onAction="#handleClose"
                style="-fx-background-color: transparent; -fx-text-fill: white; -fx-font-size: 18; -fx-font-weight: 800; -fx-cursor: hand;"/>
    </HBox>

    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <VBox spacing="16" style="-fx-padding: 18 22 20 22;">
            <HBox spacing="16">
                <VBox spacing="12" HBox.hgrow="ALWAYS">
                    <StackPane style="-fx-background-color: #E2E8F0; -fx-background-radius: 14; -fx-border-color: #CBD5E1; -fx-border-radius: 14;">
                        <ImageView fx:id="mainImageView" fitWidth="610" fitHeight="320" preserveRatio="true"/>
                    </StackPane>

                    <HBox alignment="CENTER_LEFT" spacing="8">
                        <Label text="Gallery:" style="-fx-text-fill: #334155; -fx-font-weight: 700;"/>
                        <Label fx:id="galleryCountLabel" text="0 image(s)" style="-fx-text-fill: #64748B; -fx-font-size: 12;"/>
                        <Label text="• Drag thumbnails to reorder"
                               style="-fx-text-fill: #0A4174; -fx-font-size: 11; -fx-font-weight: 700;"/>
                        <Region HBox.hgrow="ALWAYS"/>
                        <Label fx:id="imageMetaLabel" text="No image selected" style="-fx-text-fill: #64748B; -fx-font-size: 12;"/>
                    </HBox>

                    <ScrollPane fitToHeight="true" fitToWidth="false" hbarPolicy="AS_NEEDED" vbarPolicy="NEVER"
                                style="-fx-background-color: transparent; -fx-border-color: transparent;">
                        <HBox fx:id="thumbnailsContainer" spacing="8" style="-fx-padding: 6 4;"/>
                    </ScrollPane>

                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Button text="Upload Images" onAction="#handleUploadImages"
                                styleClass="btn-secondary"
                                style="-fx-font-weight: 700; -fx-padding: 8 14;"/>
                        <Button fx:id="setPrimaryButton" text="Set Primary" onAction="#handleSetPrimary"
                                style="-fx-background-color: #0EA5A4; -fx-text-fill: white; -fx-font-weight: 700; -fx-padding: 8 14; -fx-background-radius: 10; -fx-cursor: hand;"/>
                        <Button fx:id="moveLeftButton" text="Move Left" onAction="#handleMoveLeft"
                                style="-fx-background-color: #1D4ED8; -fx-text-fill: white; -fx-font-weight: 700; -fx-padding: 8 14; -fx-background-radius: 10; -fx-cursor: hand;"/>
                        <Button fx:id="moveRightButton" text="Move Right" onAction="#handleMoveRight"
                                style="-fx-background-color: #1D4ED8; -fx-text-fill: white; -fx-font-weight: 700; -fx-padding: 8 14; -fx-background-radius: 10; -fx-cursor: hand;"/>
                        <Button fx:id="deleteImageButton" text="Delete Image" onAction="#handleDeleteImage"
                                style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-font-weight: 700; -fx-padding: 8 14; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>

                <VBox spacing="12" prefWidth="310" minWidth="310" maxWidth="310"
                      style="-fx-background-color: linear-gradient(to bottom right, #FFFFFF, #F8FAFC); -fx-border-color: #DBEAFE; -fx-border-radius: 14; -fx-background-radius: 14; -fx-padding: 14;">
                    <Label fx:id="roomNameLabel" text="Room"
                           style="-fx-text-fill: #0F172A; -fx-font-size: 19; -fx-font-weight: 800;"/>
                    <Label fx:id="roomTypeLabel" text="Type: -"
                           style="-fx-text-fill: #334155; -fx-font-size: 13; -fx-font-weight: 600;"/>
                    <Label fx:id="capacityLabel" text="Capacity: -"
                           style="-fx-text-fill: #334155; -fx-font-size: 13; -fx-font-weight: 600;"/>
                    <Label fx:id="sizeLabel" text="Size: -"
                           style="-fx-text-fill: #334155; -fx-font-size: 13; -fx-font-weight: 600;"/>
                    <Label fx:id="priceLabel" text="Price: -"
                           style="-fx-text-fill: #0F766E; -fx-font-size: 14; -fx-font-weight: 800;"/>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Label text="Status:" style="-fx-text-fill: #334155; -fx-font-size: 12; -fx-font-weight: 700;"/>
                        <Label fx:id="statusLabel" text="-" style="-fx-font-size: 12;"/>
                    </HBox>
                    <HBox spacing="8" alignment="CENTER_LEFT">
                        <Button text="Edit Room" onAction="#handleEditRoom"
                                style="-fx-background-color: #2563EB; -fx-text-fill: white; -fx-font-weight: 700; -fx-padding: 7 12; -fx-background-radius: 10; -fx-cursor: hand;"/>
                        <Button text="Delete Room" onAction="#handleDeleteRoom"
                                style="-fx-background-color: #DC2626; -fx-text-fill: white; -fx-font-weight: 700; -fx-padding: 7 12; -fx-background-radius: 10; -fx-cursor: hand;"/>
                    </HBox>

                    <Separator/>
                    <Label text="Description" style="-fx-text-fill: #0F172A; -fx-font-size: 14; -fx-font-weight: 800;"/>
                    <Label fx:id="roomDescriptionLabel" wrapText="true"
                           style="-fx-text-fill: #475569; -fx-font-size: 12.5;"/>

                    <Separator/>
                    <Label text="Amenities" style="-fx-text-fill: #0F172A; -fx-font-size: 14; -fx-font-weight: 800;"/>
                    <VBox fx:id="amenitiesContainer" spacing="4" VBox.vgrow="ALWAYS"/>
                </VBox>
            </HBox>
        </VBox>
    </ScrollPane>
</VBox>
