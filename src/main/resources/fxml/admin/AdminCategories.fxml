<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.admin.AdminCategoriesController"
      spacing="24" style="-fx-background-color: #F5F7FA;">
    
    <padding>
        <Insets top="32" right="32" bottom="32" left="32"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="24">
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Pack Categories" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1A202C;"/>
            <Label text="Organize your travel packages" style="-fx-font-size: 14px; -fx-text-fill: #718096;"/>
        </VBox>
        
        <Button fx:id="btnAddCategory" text="✚ Add Category" 
                style="-fx-background-color: linear-gradient(to bottom right, #4facfe, #00f2fe); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 12; -fx-padding: 14 28; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(79,172,254,0.4), 15, 0, 0, 5);"/>
    </HBox>

    <!-- Stats -->
    <HBox spacing="35">
        <VBox spacing="5" style="-fx-background-color: linear-gradient(to bottom right, #4facfe, #00f2fe); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <Label text="🏷" style="-fx-font-size: 32px;"/>
            <Label fx:id="lblTotalCategories" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Total Categories" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
        </VBox>
        
        <VBox spacing="5" style="-fx-background-color: linear-gradient(to bottom right, #a8edea, #fed6e3); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <Label text="📦" style="-fx-font-size: 32px;"/>
            <Label fx:id="lblTotalPacks" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: #1A202C;"/>
            <Label text="Total Packs" style="-fx-font-size: 14px; -fx-text-fill: #4A5568; -fx-font-weight: 600;"/>
        </VBox>
    </HBox>

    <!-- Search Bar -->
    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 2);">
        <Label text="🔍" style="-fx-font-size: 20px;"/>
        <TextField fx:id="searchField" promptText="Search categories..." 
                   prefWidth="400"
                   style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 13px;"
                   HBox.hgrow="ALWAYS"/>
    </HBox>

    <!-- Categories Grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <FlowPane fx:id="categoriesGrid" hgap="20" vgap="35"
                  style="-fx-background-color: transparent; -fx-padding: 4;"/>
    </ScrollPane>

</VBox>
