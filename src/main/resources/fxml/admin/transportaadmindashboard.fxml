<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.geometry.Insets?>

<BorderPane prefWidth="1280" prefHeight="750"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="tn.esprit.controllers.admin.TransportAdminDashboardController"
            style="-fx-background-color: #F1EAE7;">

    <!-- LEFT SIDEBAR -->
    <left>
        <VBox prefWidth="220" spacing="12"
              style="-fx-background-color: #1F294C; -fx-padding: 28;">

            <Label text="ADMIN"
                   style="-fx-text-fill: #4FB3B5; -fx-font-size: 22px; -fx-font-weight: bold;" />
            <Label text="DASHBOARD"
                   style="-fx-text-fill: #FFFFFF; -fx-font-size: 22px; -fx-font-weight: bold;" />

            <Separator style="-fx-background-color: #4FB3B5;" />

            <Button fx:id="btnTransport"
                    text="Manage Transport"
                    maxWidth="Infinity"
                    onAction="#showTransportTab"
                    style="-fx-background-color: #4FB3B5; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 10 15 10 15; -fx-cursor: hand; -fx-background-radius: 6;" />

            <Button fx:id="btnSchedule"
                    text="Manage Schedules"
                    maxWidth="Infinity"
                    onAction="#showScheduleTab"
                    style="-fx-background-color: transparent; -fx-text-fill: #CCCCCC; -fx-font-size: 13px; -fx-padding: 10 15 10 15; -fx-cursor: hand; -fx-background-radius: 6;" />

            <Button fx:id="btnBooking"
                    text="Manage Bookings"
                    maxWidth="Infinity"
                    onAction="#showBookingTab"
                    style="-fx-background-color: transparent; -fx-text-fill: #CCCCCC; -fx-font-size: 13px; -fx-padding: 10 15 10 15; -fx-cursor: hand; -fx-background-radius: 6;" />

            <Region VBox.vgrow="ALWAYS" />

            <Separator style="-fx-background-color: #4FB3B5;" />

            <Button fx:id="btnLogout"
                    text="Logout"
                    maxWidth="Infinity"
                    onAction="#handleLogout"
                    style="-fx-background-color: #F06E32; -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 13px; -fx-padding: 10 15 10 15; -fx-cursor: hand; -fx-background-radius: 6;" />
        </VBox>
    </left>

    <!-- TOP BAR -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="15"
              style="-fx-background-color: #FFFFFF; -fx-padding: 15 25 15 25; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 4, 0, 0, 2);">
            <Label fx:id="topTitle"
                   text="Transport Module"
                   style="-fx-text-fill: #1F294C; -fx-font-size: 20px; -fx-font-weight: bold;" />
            <Region HBox.hgrow="ALWAYS" />
            <Label text="Admin Panel"
                   style="-fx-text-fill: #4FB3B5; -fx-font-size: 13px;" />
        </HBox>
    </top>

    <!-- CENTER CONTENT -->
    <center>
        <StackPane fx:id="contentArea">
            <padding>
                <Insets top="20" right="20" bottom="20" left="20" />
            </padding>
        </StackPane>
    </center>

</BorderPane>