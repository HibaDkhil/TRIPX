<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import javafx.collections.*?>
<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.paint.*?>
<?import javafx.scene.shape.*?>

<StackPane prefHeight="1000.0" prefWidth="1600.0" stylesheets="@/css/admin-style.css"
           xmlns="http://javafx.com/javafx/17.0.12"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="tn.esprit.controllers.admin.AdminAccommodationBookingController">

    <BorderPane prefHeight="1000.0" prefWidth="1600.0" styleClass="admin-root booking-shell">
        <left>
            <VBox fx:id="sidebar" maxWidth="280" minWidth="280" prefWidth="280" spacing="0" styleClass="sidebar-container">
                <HBox alignment="CENTER_LEFT" spacing="15" styleClass="sidebar-header">
                    <padding>
                        <Insets bottom="25" left="25" right="20" top="25" />
                    </padding>
                    <HBox alignment="CENTER_LEFT" spacing="12">
                        <StackPane>
                            <ImageView fitHeight="90.0" fitWidth="57.0" pickOnBounds="true" preserveRatio="true">
                                <image>
                                    <Image url="@/images/tripx-logo.png" />
                                </image>
                            </ImageView>
                        </StackPane>
                        <VBox spacing="4">
                            <Label styleClass="logo-title" text="TripX" />
                            <Label styleClass="logo-subtitle" text="Admin" />
                        </VBox>
                    </HBox>
                    <Region HBox.hgrow="ALWAYS" />
                    <Button fx:id="sidebarToggle" styleClass="sidebar-toggle-btn" text="◀">
                        <tooltip>
                            <Tooltip text="Toggle Sidebar" />
                        </tooltip>
                    </Button>
                </HBox>

                <HBox alignment="CENTER" spacing="10" styleClass="sidebar-search-container">
                    <padding>
                        <Insets bottom="15" left="20" right="20" top="15" />
                    </padding>
                    <TextField promptText="Search modules..." styleClass="sidebar-search" />
                    <Button styleClass="search-btn" text="🔍" />
                </HBox>

                <ScrollPane fitToWidth="true" styleClass="sidebar-scroll" VBox.vgrow="ALWAYS">
                    <VBox spacing="2" styleClass="sidebar-menu">
                        <VBox spacing="0" styleClass="menu-section">
                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="menu-header">
                                <Label styleClass="menu-icon" text="🏠" />
                                <Label styleClass="menu-title" text="Dashboard" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="dashboardToggle" styleClass="menu-toggle" text="▼" />
                            </HBox>
                            <VBox fx:id="dashboardMenu" spacing="0" styleClass="submenu">
                                <Button styleClass="menu-item" text="Overview" />
                                <Button styleClass="menu-item" text="Statistics" />
                                <Button styleClass="menu-item" text="Recent Activity" />
                            </VBox>
                        </VBox>

                        <VBox spacing="0" styleClass="menu-section">
                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="menu-header">
                                <Label styleClass="menu-icon" text="👤" />
                                <Label styleClass="menu-title" text="Users" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="usersToggle" styleClass="menu-toggle" text="▼" />
                            </HBox>
                            <VBox fx:id="usersMenu" spacing="0" styleClass="submenu">
                                <Button styleClass="menu-item" text="Manage Users" />
                                <Button styleClass="menu-item" text="Roles &amp; Permissions" />
                                <Button styleClass="menu-item" text="User Reports" />
                            </VBox>
                        </VBox>

                        <VBox spacing="0" styleClass="menu-section active">
                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="menu-header">
                                <Label styleClass="menu-icon" text="🏨" />
                                <Label styleClass="menu-title" text="Accommodations" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="accommodationsToggle" styleClass="menu-toggle" text="▼" />
                            </HBox>
                            <VBox fx:id="accommodationsMenu" spacing="0" styleClass="submenu" visible="true">
                                <Button styleClass="menu-item" text="Manage Accommodations" onAction="#handleBackToAccommodationAdmin" />
                                <Button styleClass="menu-item" text="Manage Bookings" onAction="#showAdminAccommodationBookingPage" />
                            </VBox>
                        </VBox>

                        <VBox spacing="0" styleClass="menu-section">
                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="menu-header">
                                <Label styleClass="menu-icon" text="🌍" />
                                <Label styleClass="menu-title" text="Destinations" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="destinationsToggle" styleClass="menu-toggle" text="▼" />
                            </HBox>
                            <VBox fx:id="destinationsMenu" spacing="0" styleClass="submenu">
                                <Button styleClass="menu-item" text="All Destinations" />
                                <Button styleClass="menu-item" text="Add Destination" />
                                <Button styleClass="menu-item" text="Categories" />
                            </VBox>
                        </VBox>

                        <VBox spacing="0" styleClass="menu-section">
                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="menu-header">
                                <Label styleClass="menu-icon" text="🎁" />
                                <Label styleClass="menu-title" text="Packs &amp; Offers" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="offersToggle" styleClass="menu-toggle" text="▼" />
                            </HBox>
                            <VBox fx:id="offersMenu" spacing="0" styleClass="submenu">
                                <Button styleClass="menu-item" text="All Offers" />
                                <Button styleClass="menu-item" text="Create Offers" />
                            </VBox>
                        </VBox>

                        <VBox spacing="0" styleClass="menu-section">
                            <HBox alignment="CENTER_LEFT" spacing="10" styleClass="menu-header">
                                <Label styleClass="menu-icon" text="🚗" />
                                <Label styleClass="menu-title" text="Transport" />
                                <Region HBox.hgrow="ALWAYS" />
                                <Button fx:id="transportToggle" styleClass="menu-toggle" text="▼" />
                            </HBox>
                            <VBox fx:id="transportMenu" spacing="0" styleClass="submenu">
                                <Button styleClass="menu-item" text="Vehicles" />
                                <Button styleClass="menu-item" text="Bookings" />
                                <Button styleClass="menu-item" text="Routes" />
                                <Button styleClass="menu-item" text="Transport Providers" />
                            </VBox>
                        </VBox>
                    </VBox>
                </ScrollPane>

                <VBox spacing="15" styleClass="sidebar-footer">
                    <Separator styleClass="sidebar-separator" />
                    <HBox alignment="CENTER_LEFT" spacing="15" styleClass="theme-toggle-container">
                        <Label styleClass="theme-icon" text="🌙" />
                        <Label styleClass="theme-label" text="Dark Mode" />
                        <Region HBox.hgrow="ALWAYS" />
                        <ToggleButton fx:id="darkModeToggle" styleClass="theme-toggle" />
                    </HBox>
                </VBox>
            </VBox>
        </left>

        <center>
            <VBox spacing="0">
                <HBox alignment="CENTER_LEFT" spacing="20" styleClass="main-header">
                    <Button fx:id="sidebarOpenButton" styleClass="sidebar-open-btn" text="☰">
                        <textFill>
                            <LinearGradient endX="1.0" endY="1.0" startX="0.6666666585387606">
                                <stops>
                                    <Stop>
                                        <color>
                                            <Color red="0.18311890959739685" green="0.5579577684402466" blue="0.6421052813529968" />
                                        </color>
                                    </Stop>
                                    <Stop offset="1.0">
                                        <color>
                                            <Color red="1.0" green="1.0" blue="1.0" />
                                        </color>
                                    </Stop>
                                </stops>
                            </LinearGradient>
                        </textFill>
                    </Button>

                    <HBox alignment="CENTER_LEFT" spacing="10" styleClass="breadcrumb-container">
                        <Label styleClass="breadcrumb-item" text="Dashboard" />
                        <Label styleClass="breadcrumb-separator" text="›" />
                        <Label styleClass="breadcrumb-item" text="Accommodations" />
                        <Label styleClass="breadcrumb-separator" text="›" />
                        <Label styleClass="breadcrumb-item active" text="Manage Bookings" />
                    </HBox>

                    <Region HBox.hgrow="ALWAYS" />

                    <HBox alignment="CENTER_RIGHT" spacing="15" styleClass="header-actions">
                        <TextField fx:id="bookingSearchField" promptText="Search booking id, user, room, phone..." styleClass="global-search" prefWidth="320" />

                        <StackPane styleClass="notification-badge">
                            <Button fx:id="notificationBtn" styleClass="icon-btn notification-btn" text="🔔">
                                <tooltip>
                                    <Tooltip text="Notifications" />
                                </tooltip>
                            </Button>
                            <Circle radius="5" styleClass="notification-dot" />
                        </StackPane>

                        <MenuButton fx:id="profileDropdown" styleClass="profile-dropdown" text="Admin User">
                            <graphic>
                                <StackPane styleClass="profile-avatar">
                                    <Circle radius="16" styleClass="avatar-circle" />
                                    <Label styleClass="avatar-text" text="AU" />
                                </StackPane>
                            </graphic>
                            <items>
                                <MenuItem text="👤 My Profile" />
                                <MenuItem text="⚙️ Settings" />
                                <SeparatorMenuItem />
                                <MenuItem text="🚪 Logout" />
                            </items>
                        </MenuButton>
                    </HBox>
                </HBox>

                <ScrollPane fitToWidth="true" style="-fx-background-color: #F5F7FA; -fx-border-color: transparent;">
                    <VBox spacing="24" VBox.vgrow="ALWAYS">
                        <padding>
                            <Insets bottom="24" left="30" right="30" top="24" />
                        </padding>

                        <VBox spacing="14" styleClass="booking-panel">
                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="Accommodation Booking Management" styleClass="booking-title"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Button text="Refresh" onAction="#handleRefresh" styleClass="booking-btn-primary"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="Status:" styleClass="booking-filter-label"/>
                                <ComboBox fx:id="statusFilter" prefWidth="180.0"/>
                                <Button text="Apply" onAction="#handleApplyFilter" styleClass="booking-btn-primary"/>
                                <Button text="Reset" onAction="#handleResetFilter" styleClass="booking-btn-soft"/>
                                <Region HBox.hgrow="ALWAYS"/>
                                <Label fx:id="selectedBookingLabel" text="No booking selected" styleClass="booking-selected-text"/>
                            </HBox>

                            <HBox alignment="CENTER_LEFT" spacing="12">
                                <Label text="Room:" styleClass="booking-filter-label"/>
                                <ComboBox fx:id="roomIdFilter" prefWidth="130.0"/>
                                <Label text="Check-In From:" styleClass="booking-filter-label"/>
                                <DatePicker fx:id="checkInFromFilter"/>
                                <Label text="Check-Out To:" styleClass="booking-filter-label"/>
                                <DatePicker fx:id="checkOutToFilter"/>
                                <Label text="Min Total:" styleClass="booking-filter-label"/>
                                <TextField fx:id="minTotalFilterField" prefWidth="110.0" promptText="0"/>
                                <Label text="Max Total:" styleClass="booking-filter-label"/>
                                <TextField fx:id="maxTotalFilterField" prefWidth="110.0" promptText="5000"/>
                            </HBox>

                            <TableView fx:id="bookingsTable" VBox.vgrow="ALWAYS" styleClass="booking-table">
                                <columns>
                                    <TableColumn fx:id="idColumn" prefWidth="80.0" text="ID"/>
                                    <TableColumn fx:id="userIdColumn" prefWidth="100.0" text="User ID"/>
                                    <TableColumn fx:id="roomIdColumn" prefWidth="100.0" text="Room ID"/>
                                    <TableColumn fx:id="checkInColumn" prefWidth="140.0" text="Check-In"/>
                                    <TableColumn fx:id="checkOutColumn" prefWidth="140.0" text="Check-Out"/>
                                    <TableColumn fx:id="totalPriceColumn" prefWidth="140.0" text="Total Price"/>
                                    <TableColumn fx:id="statusColumn" prefWidth="130.0" text="Status"/>
                                    <TableColumn fx:id="createdAtColumn" prefWidth="220.0" text="Created At"/>
                                </columns>
                            </TableView>

                            <HBox alignment="TOP_LEFT" spacing="12">
                                <VBox spacing="8" styleClass="booking-details-card" HBox.hgrow="ALWAYS">
                                    <Label text="Selected Booking Details" styleClass="booking-details-title"/>
                                    <HBox spacing="18">
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="Booking ID" styleClass="booking-detail-key"/>
                                            <Label fx:id="detailBookingIdValue" text="-" styleClass="booking-detail-value"/>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="User ID" styleClass="booking-detail-key"/>
                                            <Label fx:id="detailUserIdValue" text="-" styleClass="booking-detail-value"/>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="Room ID" styleClass="booking-detail-key"/>
                                            <Label fx:id="detailRoomIdValue" text="-" styleClass="booking-detail-value"/>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="Status" styleClass="booking-detail-key"/>
                                            <Label fx:id="detailStatusValue" text="-" styleClass="booking-detail-value"/>
                                        </VBox>
                                    </HBox>
                                    <HBox spacing="18">
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="Check-In" styleClass="booking-detail-key"/>
                                            <Label fx:id="detailCheckInValue" text="-" styleClass="booking-detail-value"/>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="Check-Out" styleClass="booking-detail-key"/>
                                            <Label fx:id="detailCheckOutValue" text="-" styleClass="booking-detail-value"/>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="Total Price" styleClass="booking-detail-key"/>
                                            <Label fx:id="detailTotalPriceValue" text="-" styleClass="booking-detail-value booking-total-value"/>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="Created At" styleClass="booking-detail-key"/>
                                            <Label fx:id="detailCreatedAtValue" text="-" styleClass="booking-detail-value"/>
                                        </VBox>
                                    </HBox>
                                    <HBox spacing="18">
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="Guests" styleClass="booking-detail-key"/>
                                            <Label fx:id="detailGuestsValue" text="-" styleClass="booking-detail-value"/>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="Phone" styleClass="booking-detail-key"/>
                                            <Label fx:id="detailPhoneValue" text="-" styleClass="booking-detail-value"/>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="Arrival Time" styleClass="booking-detail-key"/>
                                            <Label fx:id="detailArrivalTimeValue" text="-" styleClass="booking-detail-value"/>
                                        </VBox>
                                        <VBox spacing="5" HBox.hgrow="ALWAYS">
                                            <Label text="Cancelled At" styleClass="booking-detail-key"/>
                                            <Label fx:id="detailCancelledAtValue" text="-" styleClass="booking-detail-value"/>
                                        </VBox>
                                    </HBox>
                                    <VBox spacing="5">
                                        <Label text="Special Requests" styleClass="booking-detail-key"/>
                                        <Label fx:id="detailSpecialRequestsValue" text="-" wrapText="true" styleClass="booking-detail-value"/>
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label text="Reject Reason" styleClass="booking-detail-key"/>
                                        <Label fx:id="detailRejectReasonValue" text="-" wrapText="true" styleClass="booking-detail-value"/>
                                    </VBox>
                                    <VBox spacing="5">
                                        <Label text="Cancel Reason" styleClass="booking-detail-key"/>
                                        <Label fx:id="detailCancelReasonValue" text="-" wrapText="true" styleClass="booking-detail-value"/>
                                    </VBox>
                                </VBox>

                                <VBox spacing="10" styleClass="booking-actions-card">
                                    <Label text="Actions" styleClass="booking-details-title"/>
                                    <Button fx:id="confirmButton" text="Confirm Selected" onAction="#handleConfirmSelected" styleClass="booking-btn-success">
                                        <tooltip><Tooltip text="Set selected booking to CONFIRMED"/></tooltip>
                                    </Button>
                                    <Button fx:id="rejectButton" text="Reject Selected" onAction="#handleRejectSelected" styleClass="booking-btn-danger"/>
                                    <Button fx:id="cancelButton" text="Cancel Selected" onAction="#handleCancelSelected" styleClass="booking-btn-soft"/>
                                </VBox>
                            </HBox>
                        </VBox>
                    </VBox>
                </ScrollPane>
            </VBox>
        </center>
    </BorderPane>
</StackPane>
