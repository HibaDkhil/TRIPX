<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.admin.AdminPacksBookingsController"
      spacing="24" style="-fx-background-color: #F5F7FA;">
    
    <padding>
        <Insets top="10" right="32" bottom="10" left="32"/>
    </padding>

    <!-- Header -->
    <VBox spacing="8">
        <Label text="Bookings Management" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1A202C;"/>
        <Label text="Review and manage customer bookings" style="-fx-font-size: 14px; -fx-text-fill: #718096;"/>
    </VBox>

    <!-- Stats Cards -->
    <HBox spacing="20">
        <VBox spacing="12" style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <Label text="📋" style="-fx-font-size: 32px;"/>
            <Label fx:id="lblTotalBookings" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Total Bookings" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
        </VBox>
        
        <VBox spacing="12" style="-fx-background-color: linear-gradient(to bottom right, #FFA500, #FF6347); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <Label text="⏳" style="-fx-font-size: 32px;"/>
            <Label fx:id="lblPendingBookings" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Pending" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
        </VBox>
        
        <VBox spacing="12" style="-fx-background-color: linear-gradient(to bottom right, #43e97b, #38f9d7); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <Label text="✅" style="-fx-font-size: 32px;"/>
            <Label fx:id="lblConfirmedBookings" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Confirmed" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
        </VBox>
        
        <VBox spacing="12" style="-fx-background-color: linear-gradient(to bottom right, #4facfe, #00f2fe); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <Label text="💰" style="-fx-font-size: 32px;"/>
            <Label fx:id="lblTotalRevenue" text="0 TND" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Total Revenue" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
        </VBox>
    </HBox>

    <!-- Filters -->
    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 2);">
        <Label text="🔍" style="-fx-font-size: 20px;"/>
        <TextField fx:id="searchField" promptText="Search by user ID or pack..." 
                   prefWidth="300"
                   style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 13px;"/>
        
        <Separator orientation="VERTICAL" style="-fx-background-color: #E2E8F0;"/>
        
        <VBox spacing="4">
            <Label text="Status" style="-fx-font-size: 11px; -fx-text-fill: #718096; -fx-font-weight: 600;"/>
            <ComboBox fx:id="statusFilter" prefWidth="150"
                      style="-fx-background-color: #F7FAFC; -fx-background-radius: 10;"/>
        </VBox>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <Button fx:id="btnClearFilters" text="↻ Reset"
                style="-fx-background-color: #EDF2F7; -fx-text-fill: #4A5568; -fx-font-weight: 600; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
    </HBox>

    <!-- Bookings Grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <FlowPane fx:id="bookingsGrid" hgap="10" vgap="10"
                  style="-fx-background-color: transparent; -fx-padding: 4;"/>
    </ScrollPane>

</VBox>
