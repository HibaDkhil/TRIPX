<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.admin.AdminOffersController"
      spacing="20" style="-fx-background-color: #F5F7FA;">
    
    <padding>
        <Insets top="24" right="24" bottom="24" left="24"/>
    </padding>

    <!-- Header -->
    <HBox alignment="CENTER_LEFT" spacing="16">
        <Label text="Manage Offers" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #063154;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Button fx:id="btnAddOffer" text="➕ Add Offer" 
                style="-fx-background-color: #0A4174; -fx-text-fill: white; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 10 20; -fx-cursor: hand;"/>
    </HBox>

    <!-- Search & Filter Bar -->
    <HBox spacing="12" alignment="CENTER_LEFT">
        <TextField fx:id="searchField" promptText="Search offers..." 
                   prefWidth="300"
                   style="-fx-background-color: white; -fx-background-radius: 8; -fx-border-color: #E8EAF6; -fx-border-radius: 8; -fx-padding: 10;"/>
        
        <ComboBox fx:id="typeFilter" promptText="Filter by Type" prefWidth="150"
                  style="-fx-background-color: white; -fx-background-radius: 8;"/>
        
        <ComboBox fx:id="activeFilter" promptText="Active/Inactive" prefWidth="150"
                  style="-fx-background-color: white; -fx-background-radius: 8;"/>
        
        <Button fx:id="btnClearFilters" text="Clear Filters"
                style="-fx-background-color: #F5F7FA; -fx-border-color: #E8EAF6; -fx-background-radius: 8; -fx-padding: 10 16;"/>
    </HBox>

    <!-- Table -->
    <TableView fx:id="offersTable" VBox.vgrow="ALWAYS"
               style="-fx-background-color: white; -fx-background-radius: 12; -fx-border-color: #E8EAF6; -fx-border-radius: 12;">
        <columns>
            <TableColumn fx:id="colId" text="ID" prefWidth="60"/>
            <TableColumn fx:id="colTitle" text="Title" prefWidth="200"/>
            <TableColumn fx:id="colType" text="Type" prefWidth="120"/>
            <TableColumn fx:id="colValue" text="Discount" prefWidth="100"/>
            <TableColumn fx:id="colAppliesTo" text="Applies To" prefWidth="150"/>
            <TableColumn fx:id="colStartDate" text="Start Date" prefWidth="100"/>
            <TableColumn fx:id="colEndDate" text="End Date" prefWidth="100"/>
            <TableColumn fx:id="colActive" text="Active" prefWidth="80"/>
            <TableColumn fx:id="colActions" text="Actions" prefWidth="150"/>
        </columns>
    </TableView>

</VBox>
