<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/17"
      xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="tn.esprit.controllers.admin.AdminPacksController"
      spacing="24" style="-fx-background-color: #F5F7FA;">
    
    <padding>
        <Insets top="17" right="32" bottom="32" left="32"/>
    </padding>

    <!-- Header with Stats -->
    <HBox alignment="CENTER_LEFT" spacing="24">
        <VBox spacing="8" HBox.hgrow="ALWAYS">
            <Label text="Travel Packs" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-text-fill: #1A202C;"/>
            <Label text="Manage your travel packages and adventures" style="-fx-font-size: 14px; -fx-text-fill: #718096;"/>
        </VBox>
        
        <Button fx:id="btnAddPack" text="✚ Create New Pack" 
                style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px; -fx-background-radius: 12; -fx-padding: 14 28; -fx-cursor: hand; -fx-effect: dropshadow(gaussian, rgba(102,126,234,0.4), 15, 0, 0, 5);"/>
    </HBox>

    <!-- Stats Cards -->
    <HBox spacing="25">
        <VBox spacing="5" style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <Label text="📦" style="-fx-font-size: 32px;"/>
            <Label fx:id="lblTotalPacks" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Total Packs" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
        </VBox>
        
        <VBox spacing="5" style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <Label text="✅" style="-fx-font-size: 32px;"/>
            <Label fx:id="lblActivePacks" text="0" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Active" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
        </VBox>
        
        <VBox spacing="5" style="-fx-background-color: linear-gradient(to bottom right, #667eea, #764ba2); -fx-background-radius: 16; -fx-padding: 24; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.15), 10, 0, 0, 4);" HBox.hgrow="ALWAYS">
            <Label text="💰" style="-fx-font-size: 32px;"/>
            <Label fx:id="lblAvgPrice" text="0 TND" style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;"/>
            <Label text="Avg Price" style="-fx-font-size: 14px; -fx-text-fill: rgba(255,255,255,0.9); -fx-font-weight: 600;"/>
        </VBox>
    </HBox>

    <!-- Filters Bar -->
    <HBox spacing="16" alignment="CENTER_LEFT" style="-fx-background-color: white; -fx-background-radius: 16; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 12, 0, 0, 2);">
        <Label text="🔍" style="-fx-font-size: 20px;"/>
        <TextField fx:id="searchField" promptText="Search packs by title..." 
                   prefWidth="300"
                   style="-fx-background-color: #F7FAFC; -fx-border-color: #E2E8F0; -fx-border-radius: 10; -fx-background-radius: 10; -fx-padding: 12; -fx-font-size: 13px;"/>
        
        <Separator orientation="VERTICAL" style="-fx-background-color: #E2E8F0;"/>
        
        <VBox spacing="4">
            <Label text="Category" style="-fx-font-size: 11px; -fx-text-fill: #718096; -fx-font-weight: 600;"/>
            <ComboBox fx:id="categoryFilter" prefWidth="150"
                      style="-fx-background-color: #F7FAFC; -fx-background-radius: 10;"/>
        </VBox>
        
        <VBox spacing="4">
            <Label text="Status" style="-fx-font-size: 11px; -fx-text-fill: #718096; -fx-font-weight: 600;"/>
            <ComboBox fx:id="statusFilter" prefWidth="130"
                      style="-fx-background-color: #F7FAFC; -fx-background-radius: 10;"/>
        </VBox>
        
        <Region HBox.hgrow="ALWAYS"/>
        
        <Button fx:id="btnClearFilters" text="↻ Reset"
                style="-fx-background-color: #EDF2F7; -fx-text-fill: #4A5568; -fx-font-weight: 600; -fx-background-radius: 10; -fx-padding: 12 20; -fx-cursor: hand;"/>
    </HBox>

    <!-- Packs Grid -->
    <ScrollPane fitToWidth="true" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent; -fx-border-color: transparent;">
        <FlowPane fx:id="packsGrid" hgap="25" vgap="40"
                  style="-fx-background-color: transparent; -fx-padding: 4;"/>
    </ScrollPane>

</VBox>
