<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.shape.Circle?>

<AnchorPane prefHeight="740.0" prefWidth="1040.0" style="-fx-background-color: #F4F6FA;" xmlns="http://javafx.com/javafx/23.0.1" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tn.esprit.controllers.admin.UserManagementController">

    <VBox spacing="20" AnchorPane.topAnchor="0" AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.bottomAnchor="0" style="-fx-padding: 30;">

        <!-- BIG TITLE -->
        <Label text="👥 User Management" style="-fx-font-size: 32px; -fx-font-weight: bold; -fx-font-family: 'Poppins'; -fx-text-fill: #2c3e50;">
            <VBox.margin>
                <Insets bottom="10" />
            </VBox.margin>
        </Label>

        <Label text="Manage all registered users, their roles and permissions" style="-fx-font-size: 14px; -fx-font-family: 'Poppins'; -fx-text-fill: #7f8c8d;">
            <VBox.margin>
                <Insets bottom="20" />
            </VBox.margin>
        </Label>

        <!-- SEARCH BAR AND SORT BUTTON -->
        <HBox spacing="15" alignment="CENTER_LEFT">
            <HBox spacing="10" style="-fx-background-color: white; -fx-background-radius: 10; -fx-padding: 5; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 2);" HBox.hgrow="ALWAYS">
                <Label text="🔍" style="-fx-font-size: 18px; -fx-padding: 5 0 5 10;" />
                <TextField fx:id="searchField" promptText="Search by name, email or ID..." prefHeight="40" style="-fx-background-color: transparent; -fx-font-size: 14px; -fx-font-family: 'Poppins';" HBox.hgrow="ALWAYS" />
                <Button fx:id="searchBtn" text="Search" style="-fx-background-color: #4cccad; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 8; -fx-padding: 8 20;" />
            </HBox>

            <Button fx:id="sortBtn" text="Sort ↓" style="-fx-background-color: white; -fx-text-fill: #34495e; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 8 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 5, 0, 0, 2);">
                <HBox.margin>
                    <Insets right="10" />
                </HBox.margin>
            </Button>
        </HBox>

        <!-- MAIN CONTENT WITH TABLE AND STATS SIDEBAR -->
        <HBox spacing="20" VBox.vgrow="ALWAYS">

            <!-- TABLE SECTION -->
            <VBox spacing="15" HBox.hgrow="ALWAYS">
                <Label text="All Users" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'Poppins'; -fx-text-fill: #2c3e50;" />

                <TableView fx:id="userTable" style="-fx-background-color: white; -fx-background-radius: 15; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="idColumn" text="ID" prefWidth="50" />
                        <TableColumn fx:id="firstNameColumn" text="First Name" prefWidth="120" />
                        <TableColumn fx:id="lastNameColumn" text="Last Name" prefWidth="120" />
                        <TableColumn fx:id="emailColumn" text="Email" prefWidth="200" />
                        <TableColumn fx:id="roleColumn" text="Role" prefWidth="100" />
                        <TableColumn fx:id="statusColumn" text="Status" prefWidth="80" />
                        <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="280" />
                    </columns>
                    <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                    </columnResizePolicy>
                </TableView>
            </VBox>

            <!-- SLIDE ARROW AND STATS PANEL -->
            <HBox spacing="0" alignment="CENTER">
                <Button fx:id="slideArrowBtn" text="◀" style="-fx-background-color: #4cccad; -fx-text-fill: white; -fx-font-size: 20px; -fx-font-weight: bold; -fx-background-radius: 10 0 0 10; -fx-padding: 15 5;" prefHeight="100">
                    <effect>
                        <javafx.scene.effect.DropShadow color="#3bb89c" offsetX="2" offsetY="0" radius="5" />
                    </effect>
                </Button>

                <VBox fx:id="statsPanel" prefWidth="250" spacing="20" style="-fx-background-color: white; -fx-background-radius: 0 15 15 0; -fx-padding: 20; -fx-effect: dropshadow(three-pass-box, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <Label text="📊 User Statistics" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-font-family: 'Poppins'; -fx-text-fill: #2c3e50;" />

                    <VBox spacing="15">
                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Circle radius="25" fill="#4cccad" />
                            <VBox>
                                <Label text="Total Users" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                                <Label fx:id="totalUsersStat" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Poppins';" />
                            </VBox>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Circle radius="25" fill="#6c63ff" />
                            <VBox>
                                <Label text="Admins" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                                <Label fx:id="adminCountStat" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Poppins';" />
                            </VBox>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Circle radius="25" fill="#ffb703" />
                            <VBox>
                                <Label text="Regular Users" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                                <Label fx:id="userCountStat" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Poppins';" />
                            </VBox>
                        </HBox>

                        <HBox alignment="CENTER_LEFT" spacing="15">
                            <Circle radius="25" fill="#ef476f" />
                            <VBox>
                                <Label text="New This Week" style="-fx-font-size: 12px; -fx-text-fill: #7f8c8d;" />
                                <Label fx:id="newUsersStat" text="0" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-font-family: 'Poppins';" />
                            </VBox>
                        </HBox>
                    </VBox>

                    <Label text="⚡ Quick Actions" style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-font-family: 'Poppins'; -fx-text-fill: #2c3e50; -fx-padding: 20 0 10 0;" />

                    <Button text="+ Add New User" style="-fx-background-color: #4cccad; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12;" prefWidth="210" />
                    <Button text="📧 Send Email to All" style="-fx-background-color: #6c63ff; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12;" prefWidth="210" />
                    <Button text="📥 Export Users" style="-fx-background-color: #ffb703; -fx-text-fill: white; -fx-font-size: 14px; -fx-font-weight: bold; -fx-background-radius: 10; -fx-padding: 12;" prefWidth="210" />
                </VBox>
            </HBox>
        </HBox>
    </VBox>
</AnchorPane>